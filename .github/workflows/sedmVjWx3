name: Welcome New Contributors

on:
  issues:
    types: [opened]
  pull_request_target:
    types: [opened]

permissions:
  issues: write
  pull-requests: write

jobs:
  welcome:
    name: Welcome
    runs-on: ubuntu-latest

    steps:
      - name: Welcome first-time issue authors
        if: github.event_name == 'issues'
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GITHUB_PERSONAL_ACCESS_TOKEN || secrets.GITHUB_TOKEN }}
          script: |
            const { owner, repo } = context.repo;
            const creator = context.payload.sender.login;
            const { data: issues } = await github.rest.issues.listForRepo({
              owner, repo,
              creator,
              state: 'all',
              per_page: 2
            });
            if (issues.length <= 1) {
              await github.rest.issues.createComment({
                owner, repo,
                issue_number: context.payload.issue.number,
                body: `👋 Welcome to NasTech AI, @${creator}! Thanks for opening your first issue.\n\nOur team will review it as soon as possible. In the meantime, please make sure your issue includes enough detail to reproduce the problem or understand the feature request.`
              });
            }

      - name: Welcome first-time PR authors
        if: github.event_name == 'pull_request_target'
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GITHUB_PERSONAL_ACCESS_TOKEN || secrets.GITHUB_TOKEN }}
          script: |
            const { owner, repo } = context.repo;
            const creator = context.payload.sender.login;
            const { data: prs } = await github.rest.pulls.list({
              owner, repo,
              state: 'all',
              per_page: 100
            });
            const authorPrs = prs.filter(pr => pr.user.login === creator);
            if (authorPrs.length <= 1) {
              await github.rest.issues.createComment({
                owner, repo,
                issue_number: context.payload.pull_request.number,
                body: `🎉 Thanks for your first pull request to NasTech AI, @${creator}!\n\nA maintainer will review your changes soon. Please make sure you've read our contributing guidelines and that CI checks pass.`
              });
            }
